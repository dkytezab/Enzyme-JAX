+#ifndef XLA_HLO_TRANSFORMS_SIMPLIFIERS_RECOGNIZE_REDUCE_WINDOW_H_
+#define XLA_HLO_TRANSFORMS_SIMPLIFIERS_RECOGNIZE_REDUCE_WINDOW_H_
+
+#include "absl/container/flat_hash_set.h"
+#include "absl/status/statusor.h"
+#include "absl/strings/string_view.h"
+#include "xla/hlo/ir/hlo_module.h"
+#include "xla/hlo/pass/hlo_pass_interface.h"
+
+namespace xla {
+
+// An HLO pass that recognizes overlapping slices and pads being combined via
+// elementwise operations and transforms them into reduce_window operations.
+class RecognizeReduceWindow : public HloModulePass {
+ public:
+  RecognizeReduceWindow() = default;
+
+  absl::string_view name() const override { return "recognize-reduce-window"; }
+
+ protected:
+  absl::StatusOr<bool> RunImpl(
+      HloModule* module,
+      const absl::flat_hash_set<absl::string_view>& execution_threads) override;
+};
+
+}  // namespace xla
+
+#endif  // XLA_HLO_TRANSFORMS_SIMPLIFIERS_RECOGNIZE_REDUCE_WINDOW_H_
